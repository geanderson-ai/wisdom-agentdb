{
  "name": "wisdom-agentdb",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript clients and surfaces for Wisdom AgentDB.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "lint:py": "ruff check src tests",
    "format:py": "ruff format src tests",
    "build:ts": "pnpm exec tsc -b apps/cli packages/sdk",
    "check:ts": "pnpm exec tsc -b apps/cli packages/sdk",
    "build": "pnpm build:ts",
    "check": "pnpm lint:py && pnpm check:ts"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.2"
  }
}
